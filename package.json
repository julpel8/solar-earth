{
  "name": "solar-earth-pebble",
  "author": "julpel8",
  "description": "A Pebble watchface showing a day/night globe behind the time. The terminator follows the real position of the sun, and the night side shows city lights after dark. Center the globe on your region and configure the info lines (date, weather, sunrise/sunset, steps, a second time zone…). Globe day/night shading inspired by Joshua Simmons' Blue Pebble; clock layout and widgets inspired by Freakified's Halcyon.",
  "version": "0.3.0",
  "license": "MIT",
  "keywords": [
    "pebble-watchface",
    "earth",
    "globe",
    "solar",
    "day-night"
  ],
  "private": true,
  "scripts": {
    "check:i18n": "node scripts/check-languages.js"
  },
  "pebble": {
    "displayName": "Solar Earth",
    "uuid": "bda4a4f3-0887-428d-a834-4b1e548ce2f1",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "capabilities": [
      "location",
      "configurable",
      "health"
    ],
    "watchapp": {
      "onlyShownOnCommunication": false,
      "hiddenApp": false,
      "watchface": true
    },
    "messageKeys": [
